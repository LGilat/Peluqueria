# Ejemplo de archivo .env para configuración de entorno
# Copia este archivo a .env y ajusta los valores según tu entorno

# Configuración de Django
DJANGO_SECRET_KEY=tu_clave_secreta_aqui_cambiala_en_produccion
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Configuración de la base de datos (SQLite por defecto)
# Para PostgreSQL, descomenta y ajusta:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=nombre_de_la_base_de_datos
# DB_USER=usuario_de_la_base_de_datos
# DB_PASSWORD=contraseña_de_la_base_de_datos
# DB_HOST=localhost
# DB_PORT=5432

# Configuración de CORS (opcional)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://frontpeluqueria.netlify.app
# CSRF_TRUSTED_ORIGINS=https://frontpeluqueria.netlify.app

# Configuración de email (opcional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu_email@gmail.com
# EMAIL_HOST_PASSWORD=tu_contraseña_de_email

# Configuración de Gunicorn (opcional)
# PORT=8000
# WORKERS=4
